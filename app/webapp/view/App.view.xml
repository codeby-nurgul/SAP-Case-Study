<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:bd="sap.m"
    controllerName="product.management.controller.App"
    displayBlock="true"
>
    <!-- sideExpanded="true" ensures labels are visible by default -->
    <tnt:ToolPage id="toolPage" sideExpanded="{appView>/sideExpanded}">

        <!-- ═══ TOP HEADER BAR ═══ -->
        <tnt:header>
            <tnt:ToolHeader>
                <Button
                    id="sideNavToggleBtn"
                    icon="sap-icon://menu2"
                    type="Transparent"
                    press=".onToggleSideNav"
                    tooltip="{i18n>toggleMenu}"
                />
                <Title text="{i18n>appTitle}" level="H4" />
                <ToolbarSpacer />
                <Button
                    id="stockAlertBtn"
                    icon="sap-icon://alert"
                    type="Transparent"
                    press=".onOpenStockAlerts"
                    tooltip="{i18n>stockAlerts}"
                >
                    <customData>
                        <BadgeCustomData
                            value="{appView>/lowStockBadge}"
                            visible="{= ${appView>/lowStockCount} > 0 }"
                        />
                    </customData>
                </Button>
                <Button
                    id="themeToggleBtn"
                    text="{= ${appView>/isDarkMode} ? ${i18n>toggleLightMode} : ${i18n>toggleDarkMode} }"
                    icon="{= ${appView>/isDarkMode} ? 'sap-icon://light-mode' : 'sap-icon://dark-mode' }"
                    type="Transparent"
                    press=".onThemeToggle"
                    tooltip="{i18n>toggleDarkMode}"
                />
            </tnt:ToolHeader>
        </tnt:header>

        <!-- ═══ LEFT SIDE NAVIGATION ═══ -->
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav" selectedKey="home" class="sidebarNav">
                <tnt:NavigationList id="navList">
                    <tnt:NavigationListItem
                        text="{i18n>navHome}"
                        icon="sap-icon://home"
                        key="home"
                        select=".onNavSelect"
                    />
                    <tnt:NavigationListItem
                        text="{i18n>navProducts}"
                        icon="sap-icon://product"
                        key="products"
                        select=".onNavSelect"
                    />
                    <tnt:NavigationListItem
                        text="{i18n>navSuppliers}"
                        icon="sap-icon://supplier"
                        key="suppliers"
                        select=".onNavSelect"
                    />
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <!-- ═══ MAIN CONTENT AREA (Router target) ═══ -->
        <tnt:mainContents>
            <NavContainer id="appContent" />
        </tnt:mainContents>

    </tnt:ToolPage>
</mvc:View>
