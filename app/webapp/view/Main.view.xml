<mvc:View
	controllerName="test.controller.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'test/model/formatter'
	}">

	<Page
		title="{i18n>appTitle}"
		id="page">
		<content>



				<List
		items="{/Products}"
		headerText="Products">
		<ObjectListItem
			title="{Name}"
			type="Active"
			press="onListItemPress"
			number="{Price}"
			numberUnit="EUR">
			<firstStatus>
				<ObjectStatus
					text="{Description}"  />
			</firstStatus>
			<ObjectAttribute text="Stock : {Stock}" />
		</ObjectListItem>
	</List>
	<VBox width="500px">
	<Input placeholder="Name"/>
<Input placeholder="Description"/>
<Input placeholder="Price"/>
<Input placeholder="Stock"/>
	</VBox>
		</content>
	</Page>

</mvc:View>
