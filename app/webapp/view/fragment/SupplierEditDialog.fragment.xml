<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog id="supplierEditDialog" title="{i18n>editSupplier}" contentWidth="500px">
        <content>
            <form:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanL="4" labelSpanM="4"
                columnsL="1" columnsM="1"
            >
                <form:content>
                    <!-- Name -->
                    <Label text="{i18n>supplierName}" required="true" />
                    <Input value="{name}" valueLiveUpdate="true" />

                    <!-- Email -->
                    <Label text="{i18n>supplierEmail}" required="true" />
                    <Input value="{email}" type="Email" valueLiveUpdate="true" />

                    <!-- Phone -->
                    <Label text="{i18n>supplierPhone}" />
                    <Input value="{phone}" type="Tel" />

                    <!-- Address -->
                    <Label text="{i18n>supplierAddress}" />
                    <TextArea value="{address}" rows="2" />

                    <!-- City & Country -->
                    <Label text="{i18n>supplierCity}" />
                    <Input value="{city}" />

                    <Label text="{i18n>supplierCountry}" />
                    <Input value="{country}" />
                </form:content>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button text="{i18n>save}" type="Emphasized" press=".onSaveEditDialog" />
        </beginButton>
        <endButton>
            <Button text="{i18n>cancel}" press=".onCancelEditDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
