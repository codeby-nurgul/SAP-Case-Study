<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        title="{i18n>csvUploadTitle}"
        contentWidth="500px"
        class="csvDialog"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                <u:FileUploader
                    id="supplierCSVUploader"
                    fileType="csv"
                    placeholder="{i18n>csvSelectFile}"
                    buttonText="Browse"
                    change=".onCSVFileChange"
                    width="100%"
                    class="sapUiSmallMarginBottom"
                />

                <!-- Row count info -->
                <Text text="{csvModel>/rowCountText}" visible="{= !!${csvModel>/rowCountText} }" class="heroSubtitle sapUiSmallMarginBottom" />

                <!-- Validation Checklist -->
                <VBox visible="{= ${csvModel>/results}.length > 0 }">
                    <Title text="Validation Results" level="H4" class="cardTitle sapUiSmallMarginBottom" />
                    <List
                        items="{csvModel>/results}"
                        noDataText="No validation run yet"
                    >
                        <CustomListItem>
                            <HBox class="{= ${csvModel>type} === 'Success' ? 'csvRowSuccess' : 'csvRowError' } sapUiSmallMargin" alignItems="Center" justifyContent="SpaceBetween">
                                <HBox alignItems="Center">
                                    <core:Icon 
                                        src="{= ${csvModel>type} === 'Success' ? 'sap-icon://accept' : 'sap-icon://decline' }" 
                                        color="{= ${csvModel>type} === 'Success' ? '#188918' : '#BB0000' }" 
                                        class="sapUiSmallMarginEnd" />
                                    <VBox>
                                        <Text text="Row {csvModel>row}: {csvModel>name}" class="cardTitle" />
                                        <Text text="{csvModel>message}" visible="{= ${csvModel>type} !== 'Success' }" class="heroSubtitle" />
                                    </VBox>
                                </HBox>
                                <ObjectStatus 
                                    text="{= ${csvModel>type} === 'Success' ? 'OK' : 'Error' }" 
                                    state="{csvModel>type}" />
                            </HBox>
                        </CustomListItem>
                    </List>
                </VBox>

                <!-- Hidden legacy strip -->
                <MessageStrip id="supplierCSVMessage" visible="false" />
            </VBox>
        </content>
        <beginButton>
            <Button
                text="{i18n>uploadCSV}"
                press=".onExecuteSupplierCSVUpload"
                class="btnPrimary"
                enabled="{= ${csvModel>/canUpload} }"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancel}"
                press=".onCloseCSVDialog"
                class="btnOutline"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
