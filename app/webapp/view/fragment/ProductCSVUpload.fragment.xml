<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog title="CSV Upload" contentWidth="520px">
        <content>
            <VBox class="sapUiMediumMargin">
                <u:FileUploader
                    id="productCSVUploader"
                    fileType="csv"
                    placeholder="Select a CSV file..."
                    change=".onCSVFileChange"
                    width="100%"
                    class="sapUiSmallMarginBottom"
                />

                <!-- "dosya.csv (5 rows)" -->
                <Text
                    text="{csvModel>/rowCountText}"
                    visible="{= !!${csvModel>/rowCountText} }"
                    class="heroSubtitle sapUiSmallMarginBottom"
                />

                <!-- Validation Checklist -->
                <List items="{csvModel>/results}" showNoData="false" showSeparators="None">
                    <CustomListItem type="Inactive">
                        <HBox alignItems="Center" justifyContent="SpaceBetween"
                              class="sapUiTinyMarginTopBottom sapUiSmallMarginBeginEnd">
                            <!-- Sol: renkli çizgi + ikon + metin -->
                            <HBox alignItems="Center">
                                <core:Icon
                                    src="{= ${csvModel>type} === 'Success' ? 'sap-icon://accept' : 'sap-icon://decline'}"
                                    color="{= ${csvModel>type} === 'Success' ? '#188918' : '#BB0000'}"
                                    size="1rem"
                                    class="sapUiSmallMarginEnd" />
                                <VBox>
                                    <Text text="{csvModel>name}" />
                                    <Text
                                        text="{csvModel>message}"
                                        visible="{= ${csvModel>type} !== 'Success' &amp;&amp; !!${csvModel>message} }"
                                        class="heroSubtitle" />
                                </VBox>
                            </HBox>
                            <!-- Sağ: OK / Error -->
                            <ObjectStatus
                                text="{= ${csvModel>type} === 'Success' ? 'OK' : 'Error'}"
                                state="{= ${csvModel>type} === 'Success' ? 'Success' : 'Error'}" />
                        </HBox>
                    </CustomListItem>
                </List>

                <MessageStrip id="productCSVMessage" visible="false" />
            </VBox>
        </content>
        <beginButton>
            <Button
                text="CSV Upload"
                icon="sap-icon://upload"
                type="Emphasized"
                press=".onExecuteProductCSVUpload"
                enabled="{= ${csvModel>/canUpload} }"
            />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCloseCSVDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
