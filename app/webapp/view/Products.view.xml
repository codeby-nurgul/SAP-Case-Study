<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    controllerName="product.management.controller.Products"
>
    <f:FlexibleColumnLayout id="productsFCL" layout="OneColumn">

        <!-- ═══════════════════════════════════════════════
             BEGIN COLUMN — Master: Product Table
             ═══════════════════════════════════════════════ -->
        <f:beginColumnPages>
            <Page id="productsListPage" title="{i18n>productsTitle}" enableScrolling="false">
                <content>
                    <t:Table
                        id="productsTable"
                        rows="{
                            path: '/Products',
                            parameters: {
                                $count: true,
                                $expand: 'supplier'
                            },
                            sorter: { path: 'createdAt', descending: true }
                        }"
                        selectionMode="MultiToggle"
                        selectionBehavior="RowSelector"
                        rowSelectionChange=".onRowSelectionChange"
                        sort=".onSort"
                        visibleRowCountMode="Auto"
                        minAutoRowCount="5"
                        enableSelectAll="true"
                    >
                        <!-- ── TOOLBAR ── -->
                        <t:extension>
                            <OverflowToolbar>
                                <ToolbarSpacer />
                                <SearchField
                                    id="productsSearch"
                                    width="250px"
                                    search=".onSearch"
                                    placeholder="{i18n>searchProducts}"
                                />
                                <Button
                                    icon="sap-icon://filter"
                                    text="{i18n>filter}"
                                    press=".onOpenFilterDialog"
                                    type="Transparent"
                                />
                                <ToolbarSeparator />
                                <Button
                                    icon="sap-icon://add"
                                    text="{i18n>addProduct}"
                                    press=".onAddProduct"
                                    type="Emphasized"
                                />
                                <Button
                                    icon="sap-icon://delete"
                                    text="{i18n>delete}"
                                    press=".onDeleteProducts"
                                    type="Reject"
                                />
                                <Button
                                    icon="sap-icon://upload"
                                    text="{i18n>uploadCSV}"
                                    press=".onOpenCSVDialog"
                                    type="Transparent"
                                />
                                <ToolbarSeparator />
                                <Button
                                    icon="sap-icon://save"
                                    text="{i18n>save}"
                                    press=".onSaveChanges"
                                    type="Emphasized"
                                />
                                <Button
                                    icon="sap-icon://sys-cancel-2"
                                    text="{i18n>cancel}"
                                    press=".onCancelChanges"
                                    type="Transparent"
                                />
                            </OverflowToolbar>
                        </t:extension>

                        <!-- ── TABLE COLUMNS ── -->
                        <t:columns>
                            <t:Column width="14rem" sortProperty="name" filterProperty="name">
                                <Label text="{i18n>productName}" />
                                <t:template>
                                    <Input value="{name}" valueLiveUpdate="true" />
                                </t:template>
                            </t:Column>

                            <t:Column sortProperty="description" filterProperty="description">
                                <Label text="{i18n>productDescription}" />
                                <t:template>
                                    <Input value="{description}" />
                                </t:template>
                            </t:Column>

                            <t:Column width="8rem" sortProperty="price" filterProperty="price" hAlign="End">
                                <Label text="{i18n>productPrice}" />
                                <t:template>
                                    <Input value="{price}" type="Number" />
                                </t:template>
                            </t:Column>

                            <t:Column width="7rem" sortProperty="stock" filterProperty="stock" hAlign="End">
                                <Label text="{i18n>productStock}" />
                                <t:template>
                                    <Input value="{stock}" type="Number" />
                                </t:template>
                            </t:Column>

                            <t:Column width="12rem">
                                <Label text="{i18n>productSupplier}" />
                                <t:template>
                                    <Select
                                        selectedKey="{supplier_ID}"
                                        forceSelection="false"
                                        items="{suppliersList>/items}"
                                        autoAdjustWidth="true"
                                    >
                                        <core:Item key="{suppliersList>ID}" text="{suppliersList>name}" />
                                    </Select>
                                </t:template>
                            </t:Column>
                        </t:columns>
                    </t:Table>
                </content>
            </Page>
        </f:beginColumnPages>

        <!-- ═══════════════════════════════════════════════
             MID COLUMN — Detail: Product Info
             ═══════════════════════════════════════════════ -->
        <f:midColumnPages>
            <Page id="productDetailPage" title="{i18n>productDetail}">
                <headerContent>
                    <Button icon="sap-icon://full-screen"  press=".onToggleDetailFullScreen" tooltip="Full Screen" />
                    <Button icon="sap-icon://decline"      press=".onCloseDetail"            tooltip="{i18n>close}" />
                </headerContent>
                <content>
                    <form:SimpleForm
                        id="productDetailForm"
                        editable="false"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                        class="sapUiMediumMarginTopBottom"
                    >
                        <form:title>
                            <core:Title text="{i18n>productDetail}" />
                        </form:title>
                        <Label text="{i18n>productName}" />
                        <Text text="{name}" />
                        <Label text="{i18n>productDescription}" />
                        <Text text="{description}" />
                        <Label text="{i18n>productPrice}" />
                        <ObjectNumber number="{price}" unit="TRY" />
                        <Label text="{i18n>productStock}" />
                        <ObjectNumber number="{stock}" />
                        <Label text="{i18n>productSupplier}" />
                        <Text text="{supplier/name}" />
                    </form:SimpleForm>
                </content>
            </Page>
        </f:midColumnPages>

    </f:FlexibleColumnLayout>
</mvc:View>
