<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    controllerName="product.management.controller.Products"
>
    <f:FlexibleColumnLayout id="productsFCL" layout="{appView>/layout}">

        <!-- ═══════════════════════════════════════════════
             BEGIN COLUMN — Master: Product Table
             ═══════════════════════════════════════════════ -->
        <f:beginColumnPages>
            <Page id="productsListPage" showHeader="false" enableScrolling="false">
                <content>
                    <VBox fitContainer="true" class="sapUiMediumMarginBeginEnd">
                        <!-- Custom Page Header -->
                        <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiMediumMargin">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://product" size="2rem" color="#0070F2" class="sapUiSmallMarginEnd" />
                                <VBox>
                                    <Title text="{i18n>productsTitle}" class="heroTitle" />
                                    <Text text="{i18n>productsSubtitle}" class="heroSubtitle" />
                                </VBox>
                            </HBox>
                        </HBox>

                        <t:Table
                            id="productsTable"
                            width="100%"
                            class="blueTable sapUiSmallMarginBeginEnd"
                            rows="{
                                path: '/Products',
                                parameters: {
                                    $count: true,
                                    $expand: 'supplier',
                                    $$updateGroupId: 'batchUpdate'
                                },
                                sorter: { path: 'createdAt', descending: true }
                            }"
                            selectionMode="MultiToggle"
                            selectionBehavior="RowSelector"
                            rowSelectionChange=".onRowSelectionChange"
                            sort=".onSort"
                            visibleRowCountMode="Auto"
                            minAutoRowCount="8"
                            enableSelectAll="true"
                        >
                            <!-- ── OVERFLOW TOOLBAR ── -->
                            <t:extension>
                                <OverflowToolbar style="Clear">
                                    <Title text="{i18n>productsTitle} ({$count})" level="H2" class="cardTitle" />
                                    <ToolbarSpacer />
                                    <SearchField
                                        id="productsSearch"
                                        width="300px"
                                        search=".onSearch"
                                        placeholder="{i18n>searchProducts}"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="High" />
                                        </layoutData>
                                    </SearchField>
                                    <Button
                                        icon="sap-icon://filter"
                                        press=".onOpenFilterDialog"
                                        type="Transparent"
                                        tooltip="{i18n>filter}"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        text="{i18n>addProduct}"
                                        icon="sap-icon://add"
                                        press=".onAddProduct"
                                        class="btnPrimary"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="NeverOverflow" />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        text="{i18n>uploadCSV}"
                                        icon="sap-icon://upload"
                                        press=".onOpenCSVDialog"
                                        class="btnOutline"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        text="{i18n>exportCSV}"
                                        icon="sap-icon://download"
                                        press=".onExportCSV"
                                        class="btnOutline"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                    <!-- FIX: AlwaysOverflow → Low
                                         Geniş ekranda (OneColumn) görünür,
                                         TwoColumns layout'ta toolbar daraldığında overflow menüye gider -->
                                    <Button
                                        id="deleteProductsBtn"
                                        text="{i18n>delete}"
                                        icon="sap-icon://delete"
                                        press=".onDeleteProducts"
                                        class="btnReject"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                </OverflowToolbar>
                            </t:extension>

                            <!-- ── TABLE COLUMNS ── -->
                            <t:columns>
                                <!-- Name -->
                                <t:Column sortProperty="name" filterProperty="name">
                                    <Label text="{i18n>productName}" />
                                    <t:template>
                                        <Input
                                            value="{name}"
                                            valueLiveUpdate="true"
                                            liveChange=".onNameLiveChange"
                                            class="editInput" />
                                    </t:template>
                                </t:Column>

                                <!-- Description -->
                                <t:Column sortProperty="description">
                                    <Label text="{i18n>productDescription}" />
                                    <t:template>
                                        <Input value="{description}" valueLiveUpdate="true" class="editInput" />
                                    </t:template>
                                </t:Column>

                                <!-- Price -->
                                <t:Column hAlign="End" sortProperty="price">
                                    <Label text="{i18n>productPrice}" />
                                    <t:template>
                                        <Input
                                            value="{
                                                path: 'price',
                                                type: 'sap.ui.model.odata.type.Decimal',
                                                constraints: { precision: 10, scale: 2 },
                                                formatOptions: { groupingEnabled: false }
                                            }"
                                            valueLiveUpdate="true"
                                            textAlign="End"
                                            class="editInput" />
                                    </t:template>
                                </t:Column>

                                <!-- FIX: Hardcoded "TRY" kaldırıldı → modelden binding -->
                                <t:Column>
                                    <Label text="{i18n>currency}" />
                                    <t:template>
                                        <Text text="{currency}" />
                                    </t:template>
                                </t:Column>

                                <!-- Stock -->
                                <t:Column hAlign="End" sortProperty="stock">
                                    <Label text="{i18n>productStock}" />
                                    <t:template>
                                        <Input value="{stock}" valueLiveUpdate="true" type="Number" textAlign="End" class="editInput" />
                                    </t:template>
                                </t:Column>

                                <!-- Supplier -->
                                <t:Column>
                                    <Label text="{i18n>productSupplier}" />
                                    <t:template>
                                        <Select
                                            selectedKey="{supplier_ID}"
                                            forceSelection="false"
                                            items="{suppliersList>/items}"
                                            width="100%"
                                            class="editInput"
                                        >
                                            <core:Item key="{suppliersList>ID}" text="{suppliersList>name}" />
                                        </Select>
                                    </t:template>
                                </t:Column>

                                <!-- Actions -->
                                <t:Column width="7rem" hAlign="Center">
                                    <Label text="{i18n>actions}" />
                                    <t:template>
                                        <HBox justifyContent="Center">
                                            <Button icon="sap-icon://grid" type="Transparent" press=".onOpenDetail" tooltip="View Detail" />
                                            <Button icon="sap-icon://edit" type="Transparent" press=".onEditRow" tooltip="Edit Row" />
                                        </HBox>
                                    </t:template>
                                </t:Column>
                            </t:columns>
                        </t:Table>
                    </VBox>

                    <!-- Sticky Save/Cancel Buttons -->
                    <HBox class="stickyBottomBtn">
                        <Button text="{i18n>save}" icon="sap-icon://save" type="Emphasized" press=".onSaveChanges" class="btnPrimary sapUiSmallMarginEnd" />
                        <Button text="{i18n>cancel}" icon="sap-icon://sys-cancel-2" press=".onCancelChanges" class="btnOutline" />
                    </HBox>
                </content>
            </Page>
        </f:beginColumnPages>

        <!-- ═══════════════════════════════════════════════
             MID COLUMN — Detail: Product Info + Supplier Info
             Case study: "Seçilen ürünün tedarikçisi bu panelde listelenmelidir"
             ═══════════════════════════════════════════════ -->
        <f:midColumnPages>
            <Page id="productDetailPage" title="{i18n>productDetail}">
                <headerContent>
                    <Button icon="sap-icon://full-screen"  press=".onToggleDetailFullScreen" tooltip="Full Screen" />
                    <Button icon="sap-icon://decline"      press=".onCloseDetail"            tooltip="{i18n>close}" />
                </headerContent>
                <content>
                    <VBox class="sapUiMediumMargin">
                        <HBox alignItems="Center" class="sapUiMediumMarginBottom">
                            <core:Icon src="sap-icon://product" size="3rem" color="#0070F2" class="sapUiSmallMarginEnd" />
                            <VBox>
                                <Title text="{name}" class="heroTitle" />
                                <Text text="ID: {ID}" class="heroSubtitle" />
                            </VBox>
                        </HBox>

                        <!-- Product Information Card -->
                        <form:SimpleForm
                            id="productDetailForm"
                            editable="false"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            class="dashboardCard"
                        >
                            <form:title>
                                <core:Title text="{i18n>productInformation}" />
                            </form:title>
                            <Label text="{i18n>productName}" />
                            <Text text="{name}" />
                            <Label text="{i18n>productDescription}" />
                            <Text text="{description}" />
                            <Label text="{i18n>productPrice}" />
                            <!-- FIX: unit hardcoded "TRY" → {currency} binding -->
                            <ObjectNumber number="{price}" unit="{currency}" />
                            <Label text="{i18n>productStock}" />
                            <HBox alignItems="Center">
                                <Text text="{stock}" class="sapUiTinyMarginEnd" />
                                <ObjectStatus
                                    text="{= ${stock} &lt; 10 ? ${i18n>lowStock} : ${i18n>inStock} }"
                                    state="{= ${stock} &lt; 10 ? 'Warning' : 'Success' }"
                                    inverted="true" />
                            </HBox>
                        </form:SimpleForm>

                        <!-- FIX: Supplier Information Card eklendi (Görsel 2 + case study uyumu)
                             supplier navigation property $expand ile geliyor -->
                        <form:SimpleForm
                            id="productSupplierForm"
                            editable="false"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            class="dashboardCard sapUiMediumMarginTop"
                        >
                            <form:title>
                                <core:Title text="{i18n>supplierInformation}" />
                            </form:title>
                            <Label text="{i18n>supplierName}" />
                            <Text text="{supplier/name}" />
                            <Label text="{i18n>supplierEmail}" />
                            <Link text="{supplier/email}" href="mailto:{supplier/email}" />
                            <Label text="{i18n>supplierPhone}" />
                            <Text text="{supplier/phone}" />
                            <!-- FIX: city ve country alanları eklendi -->
                            <Label text="{i18n>supplierCity}" />
                            <Text text="{supplier/city}" />
                            <Label text="{i18n>supplierCountry}" />
                            <Text text="{supplier/country}" />
                        </form:SimpleForm>
                    </VBox>
                </content>
            </Page>
        </f:midColumnPages>

    </f:FlexibleColumnLayout>
</mvc:View>