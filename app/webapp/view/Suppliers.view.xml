<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    controllerName="product.management.controller.Suppliers"
>
    <f:FlexibleColumnLayout id="suppliersFCL" layout="{appView>/layout}">

        <!-- Master: Supplier Table -->
        <f:beginColumnPages>
            <Page id="suppliersListPage" showHeader="false" enableScrolling="false">
                <content>
                    <VBox fitContainer="true" class="sapUiMediumMarginBeginEnd">
                        <!-- Custom Page Header -->
                        <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiMediumMargin">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://supplier" size="2rem" color="#0070F2" class="sapUiSmallMarginEnd" />
                                <VBox>
                                    <Title text="{i18n>suppliersTitle}" class="heroTitle" />
                                    <Text text="{i18n>suppliersSubtitle}" class="heroSubtitle" />
                                </VBox>
                            </HBox>
                        </HBox>

                        <t:Table
                            id="suppliersTable"
                            width="100%"
                            class="blueTable sapUiSmallMarginBeginEnd"
                            rows="{
                                path: '/Suppliers',
                                parameters: {
                                    $count: true,
                                    $$updateGroupId: 'batchUpdate'
                                },
                                sorter: { path: 'createdAt', descending: true }
                            }"
                            selectionMode="MultiToggle"
                            selectionBehavior="RowSelector"
                            rowSelectionChange=".onRowSelectionChange"
                            sort=".onSort"
                            visibleRowCountMode="Auto"
                            minAutoRowCount="5"
                            enableSelectAll="true"
                            rowHeight="48"
                        >
                            <!-- ── OVERFLOW TOOLBAR ── -->
                            <t:extension>
                                <OverflowToolbar style="Clear">
                                    <Title text="{i18n>suppliersTitle} ({$count})" level="H2" class="cardTitle" />
                                    <ToolbarSpacer />
                                    <SearchField
                                        id="suppliersSearch"
                                        width="300px"
                                        search=".onSearch"
                                        placeholder="{i18n>searchSuppliers}"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="High" />
                                        </layoutData>
                                    </SearchField>
                                    <Button
                                        icon="sap-icon://filter"
                                        press=".onOpenFilterDialog"
                                        type="Transparent"
                                        tooltip="{i18n>filter}"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        text="{i18n>addSupplier}"
                                        icon="sap-icon://add"
                                        press=".onAddSupplier"
                                        class="btnPrimary"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="NeverOverflow" />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        text="{i18n>uploadCSV}"
                                        icon="sap-icon://upload"
                                        press=".onOpenCSVDialog"
                                        class="btnOutline"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        text="{i18n>exportCSV}"
                                        icon="sap-icon://download"
                                        press=".onExportCSV"
                                        class="btnOutline"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                    <!-- FIX: AlwaysOverflow → Low
                                         Geniş ekranda (OneColumn) görünür,
                                         TwoColumns layout'ta toolbar daraldığında overflow menüye gider -->
                                    <Button
                                        id="deleteSuppliersBtn"
                                        text="{i18n>delete}"
                                        icon="sap-icon://delete"
                                        press=".onDeleteSuppliers"
                                        class="btnReject"
                                    >
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority="Low" />
                                        </layoutData>
                                    </Button>
                                </OverflowToolbar>
                                <OverflowToolbar id="filterInfoToolbar" visible="false" style="Clear">
                                    <Label id="filterInfoText" text="" class="sapUiSmallMarginBegin" />
                                </OverflowToolbar>
                            </t:extension>


                            <!-- ── TABLE COLUMNS ── -->
                            <t:Column sortProperty="name" filterProperty="name">
                                <Label text="{i18n>supplierName}" />
                                <t:template>
                                    <Input
                                        value="{name}"
                                        valueLiveUpdate="true"
                                        liveChange=".onNameLiveChange"
                                        class="editInput" />
                                </t:template>
                            </t:Column>

                            <t:Column sortProperty="email">
                                <Label text="{i18n>supplierEmail}" />
                                <t:template>
                                    <Input
                                        value="{email}"
                                        type="Email"
                                        valueLiveUpdate="true"
                                        liveChange=".onEmailLiveChange"
                                        class="editInput" />
                                </t:template>
                            </t:Column>

                            <t:Column sortProperty="phone">
                                <Label text="{i18n>supplierPhone}" />
                                <t:template>
                                    <Input value="{phone}" valueLiveUpdate="true" type="Tel" class="editInput" />
                                </t:template>
                            </t:Column>

                            <t:Column sortProperty="address">
                                <Label text="{i18n>supplierAddress}" />
                                <t:template>
                                    <Input value="{address}" valueLiveUpdate="true" class="editInput" />
                                </t:template>
                            </t:Column>

                            <t:Column width="7rem" hAlign="Center">
                                <Label text="{i18n>actions}" />
                                <t:template>
                                    <HBox justifyContent="Center">
                                        <Button icon="sap-icon://grid" type="Transparent" press=".onOpenDetail" tooltip="View Detail" />
                                        <Button icon="sap-icon://edit" type="Transparent" press=".onEditRow" tooltip="Edit Row" />
                                    </HBox>
                                </t:template>
                            </t:Column>
                        </t:Table>
                    </VBox>

                    <!-- Sticky Save/Cancel -->
                    <HBox class="stickyBottomBtn">
                        <Button text="{i18n>save}" icon="sap-icon://save" type="Emphasized" press=".onSaveChanges" class="btnPrimary sapUiSmallMarginEnd" />
                        <Button text="{i18n>cancel}" icon="sap-icon://sys-cancel-2" press=".onCancelChanges" class="btnOutline" />
                    </HBox>
                </content>
            </Page>
        </f:beginColumnPages>

        <!-- Detail: Supplier Info + Products
             Case study: "Tedarikçinin ürünleri bu panelde listelenmelidir" -->
        <f:midColumnPages>
            <Page id="supplierDetailPage" title="{i18n>supplierDetail}">
                <headerContent>
                    <Button icon="sap-icon://full-screen"  press=".onToggleDetailFullScreen" tooltip="Full Screen" />
                    <Button icon="sap-icon://decline"      press=".onCloseDetail"            tooltip="{i18n>close}" />
                </headerContent>
                <content>
                    <VBox class="sapUiMediumMargin">
                        <HBox alignItems="Center" class="sapUiMediumMarginBottom">
                            <core:Icon src="sap-icon://supplier" size="3rem" color="#0070F2" class="sapUiSmallMarginEnd" />
                            <VBox>
                                <Title text="{name}" class="heroTitle" />
                                <Text text="Supplier ID: {ID}" class="heroSubtitle" />
                            </VBox>
                        </HBox>

                        <!-- Supplier Information Card -->
                        <form:SimpleForm
                            id="supplierDetailForm"
                            editable="false"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                            class="dashboardCard"
                        >
                            <form:title>
                                <core:Title text="{i18n>supplierInformation}" />
                            </form:title>
                            <Label text="{i18n>supplierName}" />
                            <Text text="{name}" />
                            <Label text="{i18n>supplierEmail}" />
                            <Link text="{email}" href="mailto:{email}" />
                            <Label text="{i18n>supplierPhone}" />
                            <Text text="{phone}" />
                            <Label text="{i18n>supplierAddress}" />
                            <Text text="{address}" />
                            <!-- FIX: city ve country alanları eklendi -->
                            <Label text="{i18n>supplierCity}" />
                            <Text text="{city}" />
                            <Label text="{i18n>supplierCountry}" />
                            <Text text="{country}" />
                        </form:SimpleForm>

                        <!-- Products of this Supplier
                             Case study: "Tedarikçinin ürünleri bu panelde listelenmelidir"
                             FIX: Ürün kartında currency hardcoded "TRY" → {currency} binding -->
                        <Panel headerText="{i18n>supplierProducts}" class="sapUiMediumMarginTop dashboardCard">
                            <List
                                id="supplierProductsList"
                                items="{products}"
                                noDataText="{i18n>noProducts}"
                                showSeparators="Inner"
                            >
                                <CustomListItem>
                                    <HBox justifyContent="SpaceBetween" class="sapUiSmallMargin">
                                        <VBox>
                                            <Text text="{name}" class="cardTitle" />
                                            <Text
                                                text="{= ${stock} &lt; 10 ? 'Low Stock' : 'In Stock' }"
                                                class="{= ${stock} &lt; 10 ? 'badgeStockOrange' : 'badgeStockGreen' }" />
                                        </VBox>
                                        <VBox alignItems="End">
                                            <Title text="{price}" level="H3" class="heroTitle" />
                                            <!-- FIX: Hardcoded "TRY" → {currency} binding -->
                                            <Text text="{currency}" class="heroSubtitle" />
                                        </VBox>
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </Panel>
                    </VBox>
                </content>
            </Page>
        </f:midColumnPages>

    </f:FlexibleColumnLayout>
</mvc:View>