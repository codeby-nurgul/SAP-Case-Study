<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:grid="sap.ui.layout.cssgrid"
    controllerName="product.management.controller.Home"
>
    <Page id="homePage" showHeader="false" enableScrolling="true">
        <content>
            <VBox>
                <!-- ═══ HERO SECTION ═══ -->
                <VBox class="heroSection" alignItems="Center">
                    <core:Icon
                        src="sap-icon://shelf"
                        size="3rem"
                        color="#0070F2"
                        class="sapUiSmallMarginBottom"
                    />
                    <Title text="{i18n>appTitle}" class="heroTitle" />
                    <Text text="{i18n>appDescription}" class="heroSubtitle sapUiSmallMarginTop" />
                </VBox>

                <!-- ═══ KPI CARDS ═══ -->
                <HBox justifyContent="Center" class="sapUiSmallMarginTop">
                    <VBox width="100%" class="contentMaxWidth">
                        <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginBeginEnd sapUiSmallMarginBottom"
                              wrap="Wrap">

                            <!-- KPI 1: Total Products -->
                            <Panel class="kpiCard sapUiTinyMargin">
                                <content>
                                    <VBox alignItems="Center" class="sapUiSmallMargin">
                                        <core:Icon
                                            src="sap-icon://product"
                                            size="2rem"
                                            color="#0070F2"
                                            class="sapUiTinyMarginBottom"
                                        />
                                        <Title
                                            text="{kpiModel>/totalProducts}"
                                            level="H2"
                                            class="heroTitle"
                                        />
                                        <Text text="{i18n>kpiTotalProducts}" class="heroSubtitle" />
                                    </VBox>
                                </content>
                            </Panel>

                            <!-- KPI 2: Total Suppliers -->
                            <Panel class="kpiCard sapUiTinyMargin">
                                <content>
                                    <VBox alignItems="Center" class="sapUiSmallMargin">
                                        <core:Icon
                                            src="sap-icon://supplier"
                                            size="2rem"
                                            color="#0070F2"
                                            class="sapUiTinyMarginBottom"
                                        />
                                        <Title
                                            text="{kpiModel>/totalSuppliers}"
                                            level="H2"
                                            class="heroTitle"
                                        />
                                        <Text text="{i18n>kpiTotalSuppliers}" class="heroSubtitle" />
                                    </VBox>
                                </content>
                            </Panel>

                            <!-- KPI 3: Low Stock -->
                            <Panel class="kpiCard sapUiTinyMargin">
                                <content>
                                    <VBox alignItems="Center" class="sapUiSmallMargin">
                                        <core:Icon
                                            src="sap-icon://warning"
                                            size="2rem"
                                            color="#E9730C"
                                            class="sapUiTinyMarginBottom"
                                        />
                                        <Title
                                            text="{kpiModel>/lowStockCount}"
                                            level="H2"
                                            class="heroTitle"
                                        />
                                        <Text text="{i18n>kpiLowStock}" class="heroSubtitle" />
                                    </VBox>
                                </content>
                            </Panel>

                        </HBox>
                    </VBox>
                </HBox>

                <!-- ═══ DASHBOARD GRID ═══ -->
                <HBox justifyContent="Center" class="sapUiMediumMargin">
                    <VBox width="100%" class="contentMaxWidth">

                        <grid:CSSGrid gridTemplateColumns="repeat(auto-fit, minmax(400px, 1fr))" gridGap="1.5rem">

                            <!-- Card 1: Recently Added Products -->
                            <Panel class="dashboardCard">
                                <headerToolbar>
                                    <Toolbar>
                                        <Title text="{i18n>homeLatestProducts}" level="H4" />
                                        <ToolbarSpacer />
                                        <Link text="{i18n>viewAll}" press=".onNavToProducts" class="sapUiTinyMarginEnd" />
                                    </Toolbar>
                                </headerToolbar>
                                <content>
                                    <List
                                        id="homeProductsList"
                                        items="{
                                            path: '/Products',
                                            parameters: {
                                                $expand: 'supplier'
                                            },
                                            sorter: { path: 'createdAt', descending: true }
                                        }"
                                        growing="true"
                                        growingThreshold="3"
                                        growingScrollToLoad="false"
                                        noDataText="{i18n>noProducts}"
                                        showSeparators="Inner"
                                    >
                                        <CustomListItem 
                                            type="Navigation"
                                            press=".onNavToProductDetail"
                                            class="sapUiSmallMarginTopBottom">
                                            <HBox justifyContent="SpaceBetween" class="sapUiSmallMargin">
                                                <VBox>
                                                    <Text text="{name}" class="cardTitle" />
                                                    <Text text="{description}" class="sapUiTinyMarginTop sapUiSmallMarginBottom heroSubtitle" maxLines="1" />
                                                    <HBox alignItems="Center">
                                                        <!-- Stock Badge -->
                                                        <ObjectStatus
                                                            text="{= ${stock} &lt; 10 ? ${i18n>lowStock} : ${i18n>inStock} }"
                                                            state="{= ${stock} &lt; 10 ? 'Warning' : 'Success' }"
                                                            inverted="true"
                                                            class="sapUiTinyMarginEnd" />
                                                        <Text text=" • {supplier/name}" class="heroSubtitle sapUiSmallMarginBegin" visible="{= !!${supplier/name} }" />
                                                    </HBox>
                                                </VBox>
                                                <VBox alignItems="End">
                                                    <ObjectNumber number="{price}" unit="{currency}" emphasized="false" class="heroTitle" />
                                                </VBox>
                                            </HBox>
                                        </CustomListItem>
                                    </List>
                                </content>
                            </Panel>

                            <!-- Card 2: Recently Added Suppliers -->
                            <Panel class="dashboardCard">
                                <headerToolbar>
                                    <Toolbar>
                                        <Title text="{i18n>homeLatestSuppliers}" level="H4" />
                                        <ToolbarSpacer />
                                        <Link text="{i18n>viewAll}" press=".onNavToSuppliers" class="sapUiTinyMarginEnd" />
                                    </Toolbar>
                                </headerToolbar>
                                <content>
                                    <List
                                        id="homeSuppliersList"
                                        items="{
                                            path: '/Suppliers',
                                            sorter: { path: 'createdAt', descending: true }
                                        }"
                                        growing="true"
                                        growingThreshold="3"
                                        growingScrollToLoad="false"
                                        noDataText="{i18n>noSuppliers}"
                                        showSeparators="Inner"
                                    >
                                        <CustomListItem
                                            type="Navigation"
                                            press=".onNavToSupplierDetail">
                                            <VBox class="sapUiSmallMargin">
                                                <Text text="{address}" class="heroSubtitle" />
                                                <Text text="{name}" class="cardTitle sapUiTinyMarginTop" />
                                                <HBox class="sapUiSmallMarginTop">
                                                    <core:Icon src="sap-icon://email" size="0.8rem" class="sapUiTinyMarginEnd" color="#556B82" />
                                                    <Text text="{email}" class="heroSubtitle" />
                                                </HBox>
                                                <HBox class="sapUiTinyMarginTop">
                                                    <core:Icon src="sap-icon://phone" size="0.8rem" class="sapUiTinyMarginEnd" color="#556B82" />
                                                    <Text text="{phone}" class="heroSubtitle" />
                                                </HBox>
                                            </VBox>
                                        </CustomListItem>
                                    </List>
                                </content>
                            </Panel>

                        </grid:CSSGrid>
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
